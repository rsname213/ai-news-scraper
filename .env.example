# ── Claude AI ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Email Delivery ─────────────────────────────────────────────────────────────
# Gmail SMTP — requires an App Password (not your login password)
# Enable at: Google Account → Security → 2-Step Verification → App Passwords
GMAIL_ADDRESS=you@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Where the newsletter gets delivered (your email)
RECIPIENT_EMAIL=you@example.com

# ── Scraper Behaviour ──────────────────────────────────────────────────────────
LOOKBACK_DAYS=7              # Articles older than this are ignored
MAX_ARTICLES_PER_SECTION=8   # Max articles shown per newsletter section

# ── Run Mode ───────────────────────────────────────────────────────────────────
DRY_RUN=false                # Set to true to skip sending (saves HTML to data/preview.html)

# ── Optional: The Information subscriber cookie ────────────────────────────────
# Uncomment and set if you have a subscription — improves article summaries
# THEINFORMATION_SESSION_COOKIE=...
